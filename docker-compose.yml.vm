# VM deploy (Docker Hub images). Copy beside `.env`.
# Uses tag v1.0.2 and omits the `web` service (use GitHub Pages instead).

services:
  db:
    image: ${DB_IMAGE:-pgvector/pgvector:pg16}
    container_name: knowwhere-db
    environment:
      POSTGRES_USER: ${DB_SUPERUSER:-knowwhere_superadmin}
      POSTGRES_PASSWORD: ${DB_SUPERPASS:-knowwhere_superadmin_pass}
      POSTGRES_DB: knowwhere
    ports:
      - "5432:5432"
    volumes:
      - db_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${DB_SUPERUSER:-knowwhere_superadmin} -d knowwhere"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 20s

  embedding:
    image: bpmiranda/knowwhere-embedding:v1.0.2
    container_name: knowwhere-embedding
    environment:
      MODEL_NAME: ${MODEL_NAME:-BAAI/bge-small-en-v1.5}
    ports:
      - "8081:8081"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8081/health"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 60s

  reranker:
    image: bpmiranda/knowwhere-reranker:v1.0.2
    container_name: knowwhere-reranker
    environment:
      MODEL_NAME: ${RERANKER_MODEL:-cross-encoder/ms-marco-MiniLM-L-4-v2}
    ports:
      - "8082:8082"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8082/health"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 60s

  api:
    image: bpmiranda/knowwhere-api:v1.0.2
    container_name: knowwhere-api
    environment:
      NODE_ENV: production
      PORT: 3000
      API_KEY: ${API_KEY:-}
      DATABASE_URL: postgres://${DB_SUPERUSER:-knowwhere_superadmin}:${DB_SUPERPASS:-knowwhere_superadmin_pass}@db:5432/knowwhere
      EMBEDDING_ENDPOINT: http://embedding:8081/embed
      EMBEDDING_MODEL: ${EMBEDDING_MODEL:-BAAI/bge-small-en-v1.5}
      RERANK_ENDPOINT: http://reranker:8082/rerank
      RERANK_ABSTAIN: ${RERANK_ABSTAIN:-0}
      RATE_LIMIT_MAX: ${RATE_LIMIT_MAX:-100}
      RATE_LIMIT_WINDOW: ${RATE_LIMIT_WINDOW:-60000}
      TRUST_PROXY: ${TRUST_PROXY:-false}
      CORS_ORIGINS: ${CORS_ORIGINS:-}
      CONTACT_TO: ${CONTACT_TO:-knowwheretosearch@gmail.com}
      INGEST_TOPICS_STATE_FILE: /data/ingest/topics-state.json
      SMTP_HOST: ${SMTP_HOST:-}
      SMTP_PORT: ${SMTP_PORT:-587}
      SMTP_SECURE: ${SMTP_SECURE:-false}
      SMTP_USER: ${SMTP_USER:-}
      SMTP_PASS: ${SMTP_PASS:-}
      SMTP_FROM: ${SMTP_FROM:-}
    # Do not publish API directly; expose via `proxy` which injects x-api-key.
    depends_on:
      db:
        condition: service_healthy
      embedding:
        condition: service_healthy
      reranker:
        condition: service_healthy
    volumes:
      - ingest_data:/data/ingest
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:3000/health"]
      interval: 30s
      timeout: 5s
      retries: 5
      start_period: 30s

  proxy:
    build:
      context: .
      dockerfile: proxy/Dockerfile.proxy
    container_name: knowwhere-proxy
    environment:
      PROXY_UPSTREAM: http://api:3000
      # Server-side secret; never put this in GitHub Pages.
      PROXY_API_KEY: ${API_KEY:-}
      # Allow your Pages origin here (exactly), e.g. https://knowWHERE-team.github.io
      PROXY_ALLOWED_ORIGIN: ${PROXY_ALLOWED_ORIGIN:-}
    depends_on:
      - api

  # HTTPS terminator for GitHub Pages (Mixed Content requires HTTPS).
  # Uses Let's Encrypt automatically. Set CADDY_HOSTNAME to something that resolves to this VM.
  # Easiest: use nip.io, e.g. 140.245.125.172.nip.io
  caddy:
    image: caddy:2
    container_name: knowwhere-caddy
    environment:
      CADDY_HOSTNAME: ${CADDY_HOSTNAME:-}
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./caddy/Caddyfile:/etc/caddy/Caddyfile:ro
      - caddy_data:/data
      - caddy_config:/config
    depends_on:
      - proxy

volumes:
  db_data:
  ingest_data:
  caddy_data:
  caddy_config:

